      }

      /* reveal + shudder */
      .reveal { opacity: 0; transform: translateY(16px); animation: rise-in 1s cubic-bezier(.2,.7,.2,1) forwards; animation-delay: var(--d, 0s); }
      @keyframes rise-in { to { opacity: 1; transform: none; } }
      .scene.shudder .door-inner { animation: shudder .5s cubic-bezier(.36,.07,.19,.97); }
      @keyframes shudder { 10%,90% { transform: translate(-1px,1px);} 20%,80% { transform: translate(2px,-2px);} 30%,50%,70% { transform: translate(-4px,2px);} 40%,60% { transform: translate(4px,-1px);} }

      /* below the fold */
      .below { position: relative; z-index: 2; background: linear-gradient(180deg, #050506, #0b0b0f 30%, #08080a); border-top: 1px solid rgba(185,143,82,.12); }
      .wrap { max-width: 1040px; margin: 0 auto; padding: clamp(56px, 9vw, 110px) 24px 40px; }
      .eyebrow { font-family: var(--display); font-size: 11px; letter-spacing: .34em; text-transform: uppercase; color: var(--gold); opacity: .85; }
      .h-serif { font-family: var(--display); font-weight: 600; font-size: clamp(26px, 4.4vw, 46px); line-height: 1.1; margin: 16px 0 20px; max-width: 20ch; }
      .lede { font-size: clamp(17px, 2.1vw, 21px); line-height: 1.62; color: #cfc6b2; max-width: 62ch; }
      .lede strong { color: var(--gold-hi); font-weight: 600; }
      .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin: 48px 0 72px; }
      .card { padding: 26px 24px; border: 1px solid rgba(185,143,82,.18); border-radius: 12px; background: linear-gradient(180deg, rgba(24,24,30,.6), rgba(12,12,16,.6)); }
      .card h3 { font-family: var(--display); font-weight: 600; font-size: 20px; color: var(--ivory); margin-bottom: 10px; }
      .card p { color: var(--ash); font-size: 16.5px; line-height: 1.5; margin-bottom: 18px; }
      .btn { display: inline-block; padding: 10px 20px; border-radius: 7px; font-family: var(--display); font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: #1a1206; background: linear-gradient(180deg, var(--brass-hi), var(--brass)); box-shadow: 0 6px 16px rgba(0,0,0,.4); transition: filter .25s, transform .15s; }
      .btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
      .btn.ghost { color: var(--gold-hi); background: none; border: 1px solid rgba(246,178,60,.4); box-shadow: none; }
      .btn.ghost:hover { border-color: var(--gold); background: rgba(246,178,60,.08); }
      .soon { margin-top: 20px; }
      .soonstrip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 22px; }
      .mini { position: relative; border-radius: 10px; overflow: hidden; border: 1px solid rgba(185,143,82,.2); filter: grayscale(.2) brightness(.82); transition: filter .4s, transform .4s; }
      .mini:hover { filter: none; transform: translateY(-4px); }
      .mini img { width: 100%; display: block; }
      .mini figcaption { position: absolute; left: 0; right: 0; bottom: 0; padding: 26px 12px 10px; font-family: var(--display); font-size: 12px; letter-spacing: .08em; color: var(--ivory); background: linear-gradient(transparent, rgba(0,0,0,.85)); }
      .v2 figcaption { color: #a9e6c0; } .v3 figcaption { color: #f2b6c6; } .v4 figcaption { color: #a9d9e6; } .v5 figcaption { color: #eccf8f; }

      .foot { border-top: 1px solid rgba(185,143,82,.12); padding: 40px 24px; text-align: center; }
      .wordmark { font-family: var(--display); font-weight: 700; letter-spacing: .3em; font-size: 15px; color: var(--ash); }
      .wordmark span { color: var(--gold); }
      .foot nav { margin: 18px 0; display: flex; gap: 22px; justify-content: center; flex-wrap: wrap; }
      .foot nav a { font-size: 15px; color: var(--ash); transition: color .3s; }
      .foot nav a:hover { color: var(--gold-hi); }
      .fine { font-style: italic; font-size: 14px; color: var(--ash-dim); }

      @media (max-width: 720px) {
        .cards { grid-template-columns: 1fr; }
        .soonstrip { grid-template-columns: repeat(2, 1fr); }
        .tile { width: 40px; height: 50px; font-size: 21px; }
        .liveblock { width: 92vw; align-items: center; }
        .slot { width: 92vw; max-width: 92vw; }
        .entry { width: 100%; }
        .tiles { gap: 8px; justify-content: center; width: 100%; }
        .speak { flex-basis: 100%; margin-left: 0; margin-top: 12px; justify-content: center; }
        .caption { width: 92vw; max-width: 92vw; text-align: center; }
        .caption p { font-size: 16.5px; line-height: 1.4; text-align: center; }
        .entry-hint { font-size: 13px; }
        .chrome { gap: 6px; padding: 12px 12px; }
        .chip { height: 32px; padding: 0 9px; }
        .chip .lbl { display: none; }
        .brandmark { font-size: 9px; letter-spacing: .16em; }
        /* mobile: door is the backdrop and the seam runs through the text — scrim for legibility */
        .door-layer { filter: brightness(.5) saturate(.88); }
        .scene.live .door-layer { filter: brightness(.9) saturate(1); }
        .console { background: radial-gradient(130% 62% at 50% 42%, rgba(6,6,9,.62), rgba(6,6,9,.2) 68%, transparent); }
        .titlelock h1, .tagline, .series-cap, .caption p { text-shadow: 0 1px 2px #000, 0 2px 20px #000; }
        .series { align-items: center; }
        .sv-row { gap: 2px; }
        .sv { padding: 10px 22px 8px; }
        .series-cap { text-align: center; white-space: normal; max-width: 88vw; margin-top: 4px; }
        .series-cap .soon-note { display: none; }
        .caption p { text-shadow: 0 2px 3px #000, 0 2px 22px #000; }
      }
      @media (prefers-reduced-motion: reduce) {
        .stage, .door-inner, .seam, .ghosts span, .dust i, .reveal,
        .scene.igniting, .scene.igniting .door-inner, .scene.igniting .flare, .scene.igniting .seam, .scene.igniting .burst i { animation: none !important; }
        .stage { filter: none !important; }
        .door-inner, .reveal { opacity: 1; transform: none; }
        .flare, .burst i { opacity: 0 !important; }
      }
    </style>
  </body>
