          const letters = said.replace(/[^a-z]/gi, '').toUpperCase().slice(0, tileEls.length);
          fillTiles(letters);
          setTimeout(tryWord, 260);
        };
        rec.onerror = () => {};
        rec.onend = () => { micBtn.classList.remove('listening'); if (promptEl) promptEl.textContent = PROMPT_DEFAULT; };
