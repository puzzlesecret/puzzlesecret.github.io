---
// PuzzleSecret — Landing scene (Scene 0). MILESTONE 1 mood build, series edition.
// Two states on one page:
//   PRE  (default) — the mysterious, series-level entry: dimmed door, the glowing
//                    SEAM as hero, brand type, five-volume indicator, sound gate.
//   LIVE (on Enter) — Volume I ignites to gold; Keeper speaks; word slot rises.
// Gemini crack video + Keeper voice composite into LIVE in the next step.
const keeperFirstLine =
  "Two hundred puzzles… and hidden among them, a single word. If you found my first, speak it now — the vault is listening.";
const tiles = 6;
const volumes = [
  { rn: "I", c: "var(--v1)", rgb: "255,180,72", img: "/art/door-v10.webp", name: "The Keeper's Vault", active: true },
  { rn: "II", c: "var(--v2)", rgb: "70,210,135", img: "/art/door-v2.webp", name: "The Corsair's Chart" },
  { rn: "III", c: "var(--v3)", rgb: "236,142,172", img: "/art/door-v3.webp", name: "The Lost Love Letters" },
  { rn: "IV", c: "var(--v4)", rgb: "70,205,230", img: "/art/door-v4.webp", name: "The Silent Signal" },
  { rn: "V", c: "var(--v5)", rgb: "240,158,58", img: "/art/door-v5.webp", name: "The Hollow Oak" },
];
// mote colors: mostly gold, one of each series hue drifting through
const moteColors = [
  "var(--v1)","var(--v1)","var(--v1)","var(--v2)","var(--v1)","var(--v1)","var(--v3)",
  "var(--v1)","var(--v1)","var(--v4)","var(--v1)","var(--v5)","var(--v1)","var(--v1)",
];
const ghosts = [
  { d: "4", c: "var(--v1)" }, { d: "7", c: "var(--v1)" }, { d: "2", c: "var(--v2)" },
  { d: "9", c: "var(--v4)" }, { d: "5", c: "var(--v1)" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Sudoku with a Secret — The Keeper's Vault</title>
    <meta name="description" content="You solved the book. Now crack the vault. Speak the words hidden in Sudoku with a Secret and open three vaults of treasure and free bonus puzzles." />
    <meta property="og:title" content="Sudoku with a Secret — Crack the Keeper's Vault" />
    <meta property="og:description" content="A series of secrets. Five books, five seals. Speak the words you found in the book." />
    <meta property="og:image" content="/art/og-door.jpg" />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0a0c" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
    <link rel="preload" as="image" href="/art/door-v10.webp" />
  </head>

  <body>
    <header class="chrome" aria-label="Site controls">
      <button class="chip muted" id="soundToggle" aria-pressed="false" title="Sound on/off">
        <span class="ic" aria-hidden="true">○</span><span class="lbl">sound</span>
      </button>
      <a class="chip" href="/passport" title="Your passport"><span class="ic" aria-hidden="true">✦</span></a>
      <a class="chip" href="/shop" title="The Keeper's Commissary"><span class="ic key" aria-hidden="true">⚷</span></a>
      <button class="chip" id="menuBtn" title="Menu"><span class="ic" aria-hidden="true">≡</span></button>
    </header>

    <!-- ======================= HERO SCENE ======================= -->
    <main class="scene" id="scene">
      <div class="scene-bg" aria-hidden="true"></div>
      <div class="dust" aria-hidden="true">
        {moteColors.map((c, i) => <i style={`--n:${i}; --mc:${c}`}></i>)}
      </div>

      <div class="stage">
        <figure class="door" aria-hidden="true">
          <div class="door-inner">
            {volumes.map((v, i) => (
              <img class={`door-layer ${v.active ? "is-active" : ""}`} data-vol={i} src={v.img}
                alt="" width="1200" height="1788"
                fetchpriority={v.active ? "high" : undefined} loading={v.active ? "eager" : "lazy"} />
            ))}
            <div class="seam"></div>
            <div class="flare" aria-hidden="true"></div>
            <div class="burst" aria-hidden="true">
              {Array.from({ length: 18 }).map((_, i) => <i style={`--b:${i}`}></i>)}
            </div>
            <div class="ghosts">
              {ghosts.map((g, i) => <span style={`--g:${i}; --gc:${g.c}`}>{g.d}</span>)}
            </div>
          </div>
        </figure>

        <div class="console">
          <p class="brandmark reveal" style="--d:.1s">
            <span class="wm">PUZZLE<span>SECRET</span></span>
            <span class="sep">·</span> a series of secrets
          </p>

          <div class="titlelock reveal" style="--d:.2s">
            <h1><em>Sudoku</em> <span class="with">with a</span> <em class="sec">Secret</em></h1>
          </div>

          <!-- five-volume series selector (clickable) -->
          <div class="series reveal" style="--d:.34s" aria-label="The five volumes">
            <p class="series-lead">The series</p>
            <div class="sv-row" role="list">
              {volumes.map((v, i) => (
                <button type="button" class={`sv ${v.active ? "active" : ""}`} role="listitem"
                  style={`--c:${v.c}`} data-vol={i} data-rgb={v.rgb} data-name={v.name} data-rn={v.rn} data-active={v.active ? "1" : "0"}
                  aria-label={`Volume ${v.rn} — ${v.name}${v.active ? "" : " (coming soon)"}`}>
                  <span class="tick"></span>
                  <span class="rn">{v.rn}</span>
                </button>
              ))}
            </div>
            <p class="series-cap" id="seriesCap"><em>Volume I</em> · The Keeper's Vault <span class="soon-note">— four more secrets to come</span></p>
          </div>

          <!-- PRE: the invitation + sound gate -->
          <div class="enterblock pre-only reveal" style="--d:.5s">
            <p class="tagline">One glowing seam. A different secret sealed in every book.</p>
            <p class="soundcue">This experience <em>speaks.</em> Turn your sound up, and step to the door.</p>
            <button class="enter" id="enterBtn">Enter Volume I</button>
            <p class="g-mute">Prefer silence? <button class="linklike" id="enterMuted">Enter muted</button> — captions stay on.</p>
          </div>

          <!-- LIVE: the Keeper speaks + word slot -->
          <div class="liveblock live-only">
            <div class="caption" id="caption" role="status">
              <span class="cc-tag">The Keeper</span>
              <p id="capText"></p>
            </div>
            <div class="slot" id="slot">
              <p class="prompt" id="prompt">Speak the first word</p>
              <form class="entry" id="tileForm" autocomplete="off">
                <div class="tiles">
                  {Array.from({ length: tiles }).map((_, i) => (
                    <input class="tile" maxlength="1" inputmode="latin" aria-label={`letter ${i + 1}`} data-i={i} />
                  ))}
                </div>
                <button class="speak" type="button" id="micBtn" aria-label="Tap to speak the word using your microphone">
                  <svg class="mic" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="11" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
                  <span class="speak-lbl">Speak</span>
                </button>
              </form>
              <p class="entry-hint">Tap <em>Speak</em> and say the word aloud — or type it in the boxes.</p>
            </div>
          </div>

          <p class="side reveal" style="--d:.62s">
            <a href="#antechamber">I don't have the book yet</a>
            <span>·</span>
            <a href="/hints">I'm stuck</a>
          </p>
        </div>
      </div>

      <div class="veil" id="veil" aria-hidden="true"></div>
    </main>

    <!-- ======================= BELOW THE FOLD ======================= -->
    <section class="below">
      <div class="wrap">
        <p class="eyebrow">What is this?</p>
        <h2 class="h-serif">A book that hides a password. A vault that opens when you find it.</h2>
        <p class="lede">
          Every puzzle in <em>Sudoku with a Secret</em> is an honest sudoku — solvable with a
          pencil. But twenty of them hide a shaded key. Decode the three words they spell, bring
          them here, and three vaults swing open: treasure, lore, and free bonus puzzles —
          <strong>50, then 100, then 200</strong>. No email required. Ever.
        </p>

        <div class="cards">
          <article class="card">
            <h3>Have the book?</h3>
            <p>Speak your first word at the door above. Each vault you crack drops its rewards and stamps your passport.</p>
            <a class="btn ghost" href="#top">To the door ↑</a>
          </article>
          <article class="card">
            <h3>Don't have it yet?</h3>
            <p>Earn a look. Solve one small puzzle at the grate and glimpse the treasure — then decide.</p>
            <a class="btn" href="#antechamber">Peer inside</a>
          </article>
          <article class="card">
            <h3>Ten free puzzles a month</h3>
            <p>Join the Keeper's list for fresh puzzles and first word on the next volume. Optional, always.</p>
            <a class="btn ghost" href="/newsletter">The Keeper's list</a>
          </article>
        </div>

        <p class="eyebrow soon" id="soon-anchor">The vaults to come</p>
        <div class="soonstrip">
          <figure class="mini v2"><img src="/teasers/v2.webp" alt="Volume II — The Corsair's Chart" loading="lazy" /><figcaption>II · The Corsair's Chart</figcaption></figure>
          <figure class="mini v3"><img src="/teasers/v3.webp" alt="Volume III — The Lost Love Letters" loading="lazy" /><figcaption>III · The Lost Love Letters</figcaption></figure>
          <figure class="mini v4"><img src="/teasers/v4.webp" alt="Volume IV — The Silent Signal" loading="lazy" /><figcaption>IV · The Silent Signal</figcaption></figure>
          <figure class="mini v5"><img src="/teasers/v5.webp" alt="Volume V — The Hollow Oak" loading="lazy" /><figcaption>V · The Hollow Oak</figcaption></figure>
        </div>
      </div>

      <footer class="foot">
        <span class="wordmark">PUZZLE<span>SECRET</span></span>
        <nav>
          <a href="/shop">Shop</a><a href="/hints">Hints</a><a href="/passport">Passport</a>
          <a href="/the-keeper">The Keeper</a><a href="/faq">FAQ</a><a href="/privacy">Privacy</a>
        </nav>
        <p class="fine">Sudoku with a Secret · Volume 1 — the vaults are bonus treasure, not a prize of chance.</p>
      </footer>
    </section>

    <script define:vars={{ keeperFirstLine }}>
      const scene = document.getElementById('scene');
      const slot = document.getElementById('slot');
      const capText = document.getElementById('capText');

      /* ---- ambient drone + SFX via Web Audio (no files) ---- */
      let actx = null, master = null, ambient = null, audioReady = false, muted = false;
      function initAudio() {
        if (audioReady) return;
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return;
        actx = new AC();
        master = actx.createGain();
        master.gain.value = muted ? 0 : 0.9;
        master.connect(actx.destination);
        audioReady = true;
      }
      function resumeAudio() { if (actx && actx.state === 'suspended') actx.resume(); }
      function makeNoise() {
        const len = actx.sampleRate * 2, buf = actx.createBuffer(1, len, actx.sampleRate), d = buf.getChannelData(0);
        for (let i = 0; i < len; i++) d[i] = Math.random() * 2 - 1;
        const src = actx.createBufferSource(); src.buffer = buf; src.loop = true; return src;
      }
      function startAmbient() {
        if (!audioReady || ambient) return;
        const bus = actx.createGain(); bus.gain.value = 0; bus.connect(master);
        const lp = actx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 300; lp.Q.value = 0.7; lp.connect(bus);
        const o1 = actx.createOscillator(); o1.type = 'sawtooth'; o1.frequency.value = 55;
        const o2 = actx.createOscillator(); o2.type = 'sine'; o2.frequency.value = 41; o2.detune.value = 5;
        const g1 = actx.createGain(); g1.gain.value = 0.09; o1.connect(g1).connect(lp);
        const g2 = actx.createGain(); g2.gain.value = 0.15; o2.connect(g2).connect(lp);
        const lfo = actx.createOscillator(); lfo.type = 'sine'; lfo.frequency.value = 0.06;
        const lfoG = actx.createGain(); lfoG.gain.value = 80; lfo.connect(lfoG).connect(lp.frequency);
        const noise = makeNoise(); const nf = actx.createBiquadFilter(); nf.type = 'bandpass'; nf.frequency.value = 1100; nf.Q.value = 0.5;
        const ng = actx.createGain(); ng.gain.value = 0.006; noise.connect(nf).connect(ng).connect(bus);
        o1.start(); o2.start(); lfo.start(); noise.start();
        bus.gain.linearRampToValueAtTime(0.9, actx.currentTime + 2.5);
        ambient = { bus };
      }
      // The crack-open BOOM — plays the instant a vault door ignites (first entry AND
      // every subsequent vault crack). Layered: a low sine sweep (weight/body), a short
      // filtered-noise transient (the "crack" itself), and a brief metallic ring (the
      // riveted-steel character) so it reads as a door, not a generic explosion.
      function playBoom() {
        if (!audioReady || muted) return;
        const t = actx.currentTime;
        // body: deep sweep down, like a heavy door punching forward
        const o = actx.createOscillator(); o.type = 'sine';
        o.frequency.setValueAtTime(150, t); o.frequency.exponentialRampToValueAtTime(38, t + 0.35);
        const og = actx.createGain();
        og.gain.setValueAtTime(0.0001, t); og.gain.exponentialRampToValueAtTime(0.7, t + 0.02); og.gain.exponentialRampToValueAtTime(0.0006, t + 0.9);
        o.connect(og).connect(master); o.start(t); o.stop(t + 1.0);
        // crack: short burst of filtered noise, the sharp transient
        const crackLen = actx.sampleRate * 0.25;
        const cbuf = actx.createBuffer(1, crackLen, actx.sampleRate); const cd = cbuf.getChannelData(0);
        for (let i = 0; i < crackLen; i++) cd[i] = (Math.random() * 2 - 1) * (1 - i / crackLen);
        const csrc = actx.createBufferSource(); csrc.buffer = cbuf;
        const cf = actx.createBiquadFilter(); cf.type = 'bandpass'; cf.frequency.value = 900; cf.Q.value = 0.9;
        const cg = actx.createGain(); cg.gain.setValueAtTime(0.5, t); cg.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
        csrc.connect(cf).connect(cg).connect(master); csrc.start(t);
        // ring: brief metallic overtones (riveted steel), quick decay
        [740, 1180, 1980].forEach((f, i) => {
          const ro = actx.createOscillator(); ro.type = 'triangle'; ro.frequency.value = f;
          const rg = actx.createGain();
          rg.gain.setValueAtTime(0.0001, t + 0.01); rg.gain.exponentialRampToValueAtTime(0.06 / (i + 1), t + 0.03); rg.gain.exponentialRampToValueAtTime(0.0005, t + 0.5 + i * 0.08);
          ro.connect(rg).connect(master); ro.start(t + 0.01); ro.stop(t + 0.7);
        });
      }
      // Played only when a word is CORRECT — a deep resonant thud + a warm triumphant swell.
      function playUnlock() {
        if (!audioReady || muted) return;
        const t = actx.currentTime;
        const o = actx.createOscillator(); o.type = 'sine';
        o.frequency.setValueAtTime(95, t); o.frequency.exponentialRampToValueAtTime(46, t + 0.5);
        const og = actx.createGain();
        og.gain.setValueAtTime(0.0001, t); og.gain.exponentialRampToValueAtTime(0.5, t + 0.03); og.gain.exponentialRampToValueAtTime(0.0008, t + 1.3);
        o.connect(og).connect(master); o.start(t); o.stop(t + 1.4);
        [130.81, 196.0, 261.63].forEach((f) => { // low C-major swell
          const osc = actx.createOscillator(); osc.type = 'triangle'; osc.frequency.value = f;
          const g = actx.createGain();
          g.gain.setValueAtTime(0.0001, t + 0.05); g.gain.linearRampToValueAtTime(0.07, t + 0.5); g.gain.exponentialRampToValueAtTime(0.0008, t + 2.3);
          osc.connect(g).connect(master); osc.start(t + 0.05); osc.stop(t + 2.4);
        });
      }
      function setMuted(m) {
        muted = m;
        if ('speechSynthesis' in window) speechSynthesis.cancel();  // always stop the voice on toggle
        if (currentKeeperAudio) { try { currentKeeperAudio.pause(); } catch (e) {} }
        if (master && actx) master.gain.setTargetAtTime(m ? 0 : 0.9, actx.currentTime, 0.03);
        if (actx) { if (m) actx.suspend(); else actx.resume(); }    // suspend = truly silent
      }
      // Never let sound outlive the page: kill the voice + suspend audio when hidden or closing.
      function silenceAll() {
        try { if ('speechSynthesis' in window) speechSynthesis.cancel(); } catch (e) {}
        try { if (currentKeeperAudio) currentKeeperAudio.pause(); } catch (e) {}
        try { if (actx && actx.state === 'running') actx.suspend(); } catch (e) {}
      }
      window.addEventListener('pagehide', silenceAll);
      window.addEventListener('beforeunload', silenceAll);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) silenceAll();
        else if (!muted && actx && actx.state === 'suspended') actx.resume();
      });

      /* The Keeper's VOICE — LOCKED: Kokoro TTS "Michael," speed 0.8x (corrected 2026-07-22;
         the "0.65x" in older notes never actually shipped), natural pitch,
         inserted sentence-boundary pauses (see site/_content/keeper-vo-script.md for the
         exact reproducible recipe). Real pre-baked lines live in /audio/vo/ and are looked
         up here by their exact script text. Lines not yet recorded fall back to the
         browser's built-in speech so nothing is silent while the rest of the script is
         produced — replace fallback entries here as each new line is generated. */
      const keeperAudioFiles = {
        [keeperFirstLine]: '/audio/vo/vo_scene0_entry.wav',
        'So… you found my first word. Take what the first door guarded.': '/audio/vo/vo_vault1_entry.wav',
        'That is not the word I sealed it with.': '/audio/vo/vo_fail_1.wav',
        'Close… or not close at all. I will never tell.': '/audio/vo/vo_fail_2.wav',
        'Stubborn. Good — but perhaps you need my hints.': '/audio/vo/vo_fail_3.wav',
      };
      let keeperVoice = null;
      function pickKeeperVoice() {
        if (!('speechSynthesis' in window)) return null;
        const vs = speechSynthesis.getVoices();
        if (!vs.length) return null;
        return vs.find((v) => /en/i.test(v.lang) && /george|arthur|daniel/i.test(v.name))
          || vs.find((v) => /en-GB/i.test(v.lang))
          || vs.find((v) => /en/i.test(v.lang) && /(david|mark|male)/i.test(v.name))
          || vs.find((v) => /^en/i.test(v.lang)) || vs[0];
      }
      if ('speechSynthesis' in window) {
        keeperVoice = pickKeeperVoice();
        speechSynthesis.addEventListener('voiceschanged', () => { keeperVoice = pickKeeperVoice(); });
      }
      let currentKeeperAudio = null;
      // Returns the playing <audio> element when a real recorded line exists (so the
      // caller can sync caption timing to its actual duration), or null when it fell
      // back to browser speech (or was muted).
      function speakKeeper(text) {
        if (currentKeeperAudio) { try { currentKeeperAudio.pause(); } catch (e) {} currentKeeperAudio = null; }
        if (muted) return null;
        const src = keeperAudioFiles[text];
        if (src) {
          try {
            const a = new Audio(src);
            a.volume = 1;
            a.play().catch(() => {});
            currentKeeperAudio = a;
            return a;
          } catch (e) { /* fall through to browser speech */ }
        }
        if (!('speechSynthesis' in window)) return null;
        try {
          speechSynthesis.cancel();
          const u = new SpeechSynthesisUtterance(text.replace(/…/g, '... '));
          if (!keeperVoice) keeperVoice = pickKeeperVoice();
          if (keeperVoice) u.voice = keeperVoice;
          u.rate = 0.82; u.pitch = 0.5; u.volume = 1;
          speechSynthesis.speak(u);
        } catch (e) { /* ignore */ }
        return null;
      }

      let typeTimer = null;
      function typeCaption(text) {
        const audioEl = speakKeeper(text);   // the Keeper speaks the line as it writes out
        capText.textContent = '';
        let i = 0;
        clearInterval(typeTimer);
        const startTyping = (totalMs) => {
          const perChar = Math.max(18, totalMs / text.length);
          typeTimer = setInterval(() => {
            capText.textContent = text.slice(0, ++i);
            if (i >= text.length) clearInterval(typeTimer);
          }, perChar);
        };
        if (audioEl) {
          // sync the typewriter reveal to the real recording's actual length
          if (audioEl.readyState >= 1 && audioEl.duration) startTyping(audioEl.duration * 1000);
          else {
            audioEl.addEventListener('loadedmetadata', () => startTyping(audioEl.duration * 1000), { once: true });
            setTimeout(() => { if (i === 0) startTyping(text.length * 34); }, 1200); // safety net
          }
        } else {
          startTyping(text.length * 34);  // browser-speech fallback pacing
        }
      }

      function beginExperience(withSound = true) {
        initAudio(); resumeAudio();
        if (withSound && !muted) startAmbient();
        syncSoundIcon();
        scene.classList.add('live');
        scene.classList.add('igniting');      // crack-open: flash, widen, sparks, push-in
        if (withSound) playBoom();            // the door punches forward — deep BOOM + crack + metal ring
        setTimeout(() => scene.classList.remove('igniting'), 1500);
        setTimeout(() => typeCaption(keeperFirstLine), 1150);
        setTimeout(() => { const f = slot?.querySelector('.tile'); if (f) f.focus(); }, 1750);
      }
      document.getElementById('enterBtn')?.addEventListener('click', () => beginExperience(true));
      document.getElementById('enterMuted')?.addEventListener('click', () => { muted = true; beginExperience(false); syncSoundIcon(); });

      const q = new URLSearchParams(location.search);
      if (q.get('scene') === 'live') {   // settled live state (no crack animation) — for review
        scene.classList.add('live');
        capText.textContent = keeperFirstLine;
      }
      if (q.get('ignite') === '1') beginExperience();  // trigger the crack-open (for capturing frames)

      const st = document.getElementById('soundToggle');
      function syncSoundIcon() {
        if (!st) return;
        st.setAttribute('aria-pressed', String(!muted));
        st.querySelector('.ic').textContent = muted ? '○' : '◐';
        st.classList.toggle('muted', muted);
      }
      st?.addEventListener('click', () => {
        initAudio(); resumeAudio();
        setMuted(!muted);
        if (!muted) startAmbient();  // turning sound on starts the ambient bed
        syncSoundIcon();
      });

      // five-volume selector: hover updates caption, crossfades the door art + seam hue; click acts
      const seriesCap = document.getElementById('seriesCap');
      const capDefault = seriesCap ? seriesCap.innerHTML : '';
      const doorInner = document.querySelector('.door-inner');
      const layers = [...document.querySelectorAll('.door-layer')];
      const DEFAULT_SC = '255,178,72';
      function showVolume(idx, rgb) {
        layers.forEach((l, i) => l.classList.toggle('is-active', i === idx));
        if (doorInner) doorInner.style.setProperty('--sc', rgb || DEFAULT_SC);
      }
      document.querySelectorAll('.sv').forEach((sv) => {
        const nm = sv.dataset.name, rn = sv.dataset.rn, act = sv.dataset.active === '1';
        const vol = parseInt(sv.dataset.vol, 10) || 0, rgb = sv.dataset.rgb;
        sv.addEventListener('mouseenter', () => {
          seriesCap.innerHTML = act
            ? `<em>Volume ${rn}</em> · ${nm} <span class="soon-note">— open now</span>`
            : `<em>Volume ${rn}</em> · ${nm} <span class="soon-note">— coming soon</span>`;
          showVolume(vol, rgb);
        });
        sv.addEventListener('mouseleave', () => { seriesCap.innerHTML = capDefault; showVolume(0, DEFAULT_SC); });
        sv.addEventListener('click', () => {
          if (act) beginExperience();
          else document.getElementById('soon-anchor')?.scrollIntoView({ behavior: 'smooth' });
        });
      });
      // preview hook: ?vol=N shows volume N's art (as if hovered) for capturing frames
      const volParam = q.get('vol');
      if (volParam) document.querySelector(`.sv[data-vol="${volParam}"]`)?.dispatchEvent(new Event('mouseenter'));

      const tileEls = [...document.querySelectorAll('.tile')];
      const micBtn = document.getElementById('micBtn');
      const promptEl = document.getElementById('prompt');
      const PROMPT_DEFAULT = promptEl ? promptEl.textContent : '';

      function fillTiles(letters) { tileEls.forEach((t, i) => { t.value = letters[i] || ''; }); }

      // Word-check is SERVER-SIDE (/api/unlock). The answers never live in this bundle.
      let submitting = false;
      let misses = 0;
      const failLines = [
        'That is not the word I sealed it with.',
        'Close… or not close at all. I will never tell.',
        'Stubborn. Good — but perhaps you need my hints.',
      ];
      // SECURITY: these lines ship in the page source — they must never contain a secret word.
      // (The canon spoken lines with the words live only in the book and the VO recordings.)
      const successLines = {
        I: 'So… you found my first word. Take what the first door guarded.',
        II: 'The fire took my second plate — but you read my letter anyway. Enter.',
        III: 'Three words, three doors… and you spoke them all. The vault is yours.',
        IV: 'So — you heard the whole of it.',
      };
      function onWrong() {
        misses += 1;
        scene.classList.remove('shudder'); void scene.offsetWidth; scene.classList.add('shudder');
        typeCaption(failLines[Math.min(misses - 1, failLines.length - 1)]);
        if (misses >= 3 && slot && !document.getElementById('hintLink')) {
          const p = document.createElement('p');
          p.id = 'hintLink'; p.className = 'entry-hint';
          p.innerHTML = 'The Keeper offers <a href="/hints">a hint</a>.';
          slot.appendChild(p);
        }
      }
      function onCorrect(data) {
        misses = 0;
        playBoom();                  // this vault's door cracks open too
        playUnlock();                // the deep thud + triumphant swell — only on a correct word
        scene.classList.remove('igniting'); void scene.offsetWidth; scene.classList.add('igniting');
        setTimeout(() => scene.classList.remove('igniting'), 1400);
        typeCaption(successLines[data.act] || 'The vault opens.');
        const form = document.getElementById('tileForm');
        const hint = slot?.querySelector('.entry-hint');
        if (form) form.style.display = 'none';
        if (hint) hint.style.display = 'none';
        let panel = document.getElementById('rewardPanel');
        if (!panel && slot) { panel = document.createElement('div'); panel.id = 'rewardPanel'; panel.className = 'reward'; slot.appendChild(panel); }
        if (panel) panel.innerHTML =
          `<p class="r-tag">Vault ${data.act} — unlocked</p>` +
          `<p class="r-body">The door swings wide. Step inside…</p>`;
        setTimeout(() => { window.location.href = '/vault'; }, 2800); // walk into the 3D vault crawl
      }
      async function tryWord() {
        if (submitting) return; submitting = true;
        const word = tileEls.map((t) => t.value).join('');
        try {
          const res = await fetch('/api/unlock', {
            method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ word }),
